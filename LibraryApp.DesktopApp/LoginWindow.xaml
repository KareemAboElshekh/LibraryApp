<Window x:Class="LibraryApp.DesktopApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="229" Width="338">
    <Grid Margin="10,10,10,-38">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Username -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
            <Label Content="Username:" Width="70"/>
            <TextBox Width="180" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <!-- Password -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,5">
            <Label Content="Password:" Width="70"/>
            <PasswordBox x:Name="PasswordBox" Width="180"/>
        </StackPanel>

        <!-- Login Button -->
        <Button Grid.Row="2"
                Content="Login"
                Width="80" Height="30"
                HorizontalAlignment="Center"
                Command="{Binding LoginCommand}" Background="#FF3EAD45" />

        <!-- Error Message -->
        <TextBlock Grid.Row="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="Red"
                   Margin="0,5,0,0"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"/>
    </Grid>
</Window>
