<Window x:Class="LibraryApp.DesktopApp.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library Application" Height="574" Width="800">

    <Grid>
        <!-- بدل Command نستخدم Click -->
        <Button Content="◀ الرئيسية"
            Width="100" Height="30"
            HorizontalAlignment="Left" Margin="10"
            Click="BackToWelcome_Click" VerticalAlignment="Top" Background="#FF5C94C8"/>
        <ContentControl Content="{Binding CurrentPageViewModel}"
                    Margin="0,45,0,10"
                    HorizontalAlignment="Left"
                    Width="780" />
    </Grid>
</Window>