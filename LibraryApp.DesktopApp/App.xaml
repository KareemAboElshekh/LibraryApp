<Application
    x:Class="LibraryApp.DesktopApp.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:views="clr-namespace:LibraryApp.DesktopApp.Views"
    xmlns:vm="clr-namespace:LibraryApp.ViewModels.ViewModels;assembly=LibraryApp.ViewModels">

    <Application.Resources>
        <!-- بعد تسجيل الدخول، ShellWindow يحتضن ContentControl يعرض هذه الـ DataTemplates -->

        <DataTemplate DataType="{x:Type vm:BookReservationViewModel}">
            <views:BookReservationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UserManagementViewModel}">
            <views:UserManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BookManagementViewModel}">
            <views:BookManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ChangePasswordViewModel}">
            <views:ChangePasswordView/>
        </DataTemplate>
    </Application.Resources>


</Application>
