<Window x:Class="LibraryApp.DesktopApp.Views.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LibraryApp.DesktopApp.Views"

        Title="مرحباً" Height="238" Width="400">
    <Window.Resources>
        <!-- تأكد أنك أضفت هذا الـ Converter في مشروع DesktopApp -->
        <views:RoleToVisibilityConverter x:Key="RoleToVisibility"/>
    </Window.Resources>
    <StackPanel Margin="0,20,0,-9" HorizontalAlignment="Center">
        <TextBlock Text="{Binding Greeting}" 
                   FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <!-- أزرار التنقل -->
        <WrapPanel HorizontalAlignment="Center" ItemHeight="40" ItemWidth="120" Margin="0,10,0,0" Height="125">
            <Button Content="تغيير كلمة المرور" 
                    Command="{Binding ShowChangePasswordCommand}" Margin="5"/>
            <Button Content="حجز/إرجاع الكتب" 
                    Command="{Binding ShowBookReservationCommand}" Margin="5"/>
            <Button Content="إدارة المستخدمين" 
                    Command="{Binding ShowUserManagementCommand}" 
                    Visibility="{Binding CurrentUserTypeName, Converter={StaticResource RoleToVisibility}, ConverterParameter=Admin}" 
                    Margin="5"/>
            <Button Content="إدارة الكتب" 
                    Command="{Binding ShowBookManagementCommand}" 
                    Visibility="{Binding CurrentUserTypeName, Converter={StaticResource RoleToVisibility}, ConverterParameter=Admin}" 
                    Margin="5"/>
        </WrapPanel>
    </StackPanel>
</Window>
