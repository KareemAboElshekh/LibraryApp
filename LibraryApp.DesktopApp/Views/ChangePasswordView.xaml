<UserControl x:Class="LibraryApp.DesktopApp.Views.ChangePasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LibraryApp.ViewModels.ViewModels;assembly=LibraryApp.ViewModels">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="كلمة المرور الحالية" />
            <PasswordBox x:Name="OldPasswordBox" />

            <TextBlock Text="كلمة المرور الجديدة" Margin="0,10,0,0" />
            <PasswordBox x:Name="NewPasswordBox" />

            <Button
        Content="تغيير كلمة المرور"
        Command="{Binding ChangePasswordCommand}"
        Margin="0,10,0,0"/>

            <TextBlock
        Text="{Binding Message}"
        Foreground="Red"
        Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
