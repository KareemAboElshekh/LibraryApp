<UserControl x:Class="LibraryApp.DesktopApp.Views.BookReservationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LibraryApp.ViewModels.ViewModels;assembly=LibraryApp.ViewModels">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Available Books -->
        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="الكتب المتاحة" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox ItemsSource="{Binding AvailableBooks}"
                     SelectedItem="{Binding SelectedAvailableBook}"
                     DisplayMemberPath="BookName"
                     Height="200"/>
            <Button Content="احجز الكتاب"
                    Command="{Binding ReserveBookCommand}"
                    Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Separator -->
        <Rectangle Grid.Column="1" Width="1" Fill="Gray" HorizontalAlignment="Center"/>

        <!-- Your Reservations -->
        <StackPanel Grid.Column="2" Margin="10,0,0,0">
            <TextBlock Text="حجوزاتك" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <ListBox ItemsSource="{Binding ReservedBooks}"
                     SelectedItem="{Binding SelectedReservedBook}"
                     DisplayMemberPath="BookName"
                     Height="200"/>
            <Button Content="أعد الكتاب"
                    Command="{Binding ReturnBookCommand}"
                    Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
