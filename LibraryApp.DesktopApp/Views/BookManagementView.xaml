<UserControl x:Class="LibraryApp.DesktopApp.Views.BookManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="10">

        <!-- حقل اسم الكتاب -->
        <Label Content="اسم الكتاب:"/>
        <TextBox Text="{Binding NewBookName, UpdateSourceTrigger=PropertyChanged}"
             Margin="0,0,0,8"/>

        <!-- حقل معرف المؤلف -->
        <Label Content="معرّف المؤلف:"/>
        <TextBox Text="{Binding NewAuthorId, UpdateSourceTrigger=PropertyChanged}"
             Margin="0,0,0,8"/>

        <!-- حقل عدد الصفحات -->
        <Label Content="عدد الصفحات:"/>
        <TextBox Text="{Binding NewPages, UpdateSourceTrigger=PropertyChanged}"
             Margin="0,0,0,8"/>

        <!-- حقل سنة النشر -->
        <Label Content="سنة النشر:"/>
        <TextBox Text="{Binding NewPublishYear, UpdateSourceTrigger=PropertyChanged}"
             Margin="0,0,0,12"/>

        <!-- زر الإضافة -->
        <Button Content="إضافة كتاب"
            Command="{Binding AddBookCommand}"
            IsEnabled="{Binding AddBookCommand.CanExecute, Mode=OneWay}"
            Margin="0,0,0,12"/>

        <!-- رسالة النتيجة -->
        <TextBlock Text="{Binding Message}"
               Foreground="Red"
               Margin="0,0,0,12"/>

        <!-- قائمة الكتب -->
        <Label Content="الكتب الحالية:"/>
        <ListBox ItemsSource="{Binding Books}"
             SelectedItem="{Binding SelectedBook}"
             DisplayMemberPath="BookName"
             Height="83"
             Margin="0,0,0,12"/>

        <!-- أزرار الحذف والتحديث -->
        <!-- أزرار الحذف والتحديث -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
            <Button Content="حذف الكتاب"
              Command="{Binding DeleteBookCommand}"
              IsEnabled="{Binding DeleteBookCommand.CanExecute, Mode=OneWay}"
              Margin="0,0,8,0"/>
            <Button Content="تحديث القائمة"
              Command="{Binding LoadBooksCommand}"/>
        </StackPanel>

    </StackPanel>
</UserControl>
